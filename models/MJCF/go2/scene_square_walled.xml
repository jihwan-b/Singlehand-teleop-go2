<mujoco model="go2 square path walled">
  <include file="go2.xml"/>

  <!-- Camera centered on the 10x10 square, zoomed out enough to see it all -->
  <statistic center="5 5 0" extent="9"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="-130" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
  </asset>

  <worldbody>
    <light pos="5 5 4" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <!--
      Square path: 10 m x 10 m
      Robot spawns at corner (0, 0) — marked red.
      Walk: (0,0) → (10,0) → (10,10) → (0,10) → back

      All path geoms have contype/conaffinity=0 → no collision with robot.
      Cylinder size="radius half-height", Box size="half-extents x y z".
    -->

    <!-- Corner poles: red = robot start, orange = other corners -->
    <geom name="corner_start" type="cylinder" pos="0  0  0.25" size="0.06 0.25" rgba="1 0.1 0.1 1" contype="0" conaffinity="0"/>
    <geom name="corner_1"     type="cylinder" pos="10 0  0.25" size="0.06 0.25" rgba="1 0.5 0.0 1" contype="0" conaffinity="0"/>
    <geom name="corner_2"     type="cylinder" pos="10 10 0.25" size="0.06 0.25" rgba="1 0.5 0.0 1" contype="0" conaffinity="0"/>
    <geom name="corner_3"     type="cylinder" pos="0  10 0.25" size="0.06 0.25" rgba="1 0.5 0.0 1" contype="0" conaffinity="0"/>

    <!-- Edge lines: yellow flat boxes lying on the ground -->
    <geom name="edge_south" type="box" pos="5  0  0.01" size="5    0.04 0.01" rgba="1 1 0 0.9" contype="0" conaffinity="0"/>
    <geom name="edge_east"  type="box" pos="10 5  0.01" size="0.04 5    0.01" rgba="1 1 0 0.9" contype="0" conaffinity="0"/>
    <geom name="edge_north" type="box" pos="5  10 0.01" size="5    0.04 0.01" rgba="1 1 0 0.9" contype="0" conaffinity="0"/>
    <geom name="edge_west"  type="box" pos="0  5  0.01" size="0.04 5    0.01" rgba="1 1 0 0.9" contype="0" conaffinity="0"/>

    <!--
      Physical boundary walls: 1 m wide corridor centred on the square perimeter.
      Outer walls are 0.5 m outside each edge; inner walls are 0.5 m inside.
      Inner walls leave a 1.5 m gap at each corner to allow the robot to turn.
      Wall height 0.5 m (half-extent z=0.25), thickness 0.1 m (half-extent 0.05).
      Default contype/conaffinity → fully collidable.
    -->

    <!-- Outer walls (0.5 m outside the square perimeter) -->
    <geom name="wall_south_outer" type="box" pos=" 5.0  -0.5 0.25" size="5.5  0.05 0.25" rgba="0.55 0.55 0.55 1"/>
    <geom name="wall_east_outer"  type="box" pos="10.5   5.0 0.25" size="0.05 5.5  0.25" rgba="0.55 0.55 0.55 1"/>
    <geom name="wall_north_outer" type="box" pos=" 5.0  10.5 0.25" size="5.5  0.05 0.25" rgba="0.55 0.55 0.55 1"/>
    <geom name="wall_west_outer"  type="box" pos="-0.5   5.0 0.25" size="0.05 5.5  0.25" rgba="0.55 0.55 0.55 1"/>

    <!-- Inner walls (0.5 m inside the square perimeter, full corner-to-corner) -->
    <geom name="wall_south_inner" type="box" pos=" 5.0  0.5 0.25" size="4.5  0.05 0.25" rgba="0.55 0.55 0.55 1"/>
    <geom name="wall_east_inner"  type="box" pos=" 9.5  5.0 0.25" size="0.05 4.5  0.25" rgba="0.55 0.55 0.55 1"/>
    <geom name="wall_north_inner" type="box" pos=" 5.0  9.5 0.25" size="4.5  0.05 0.25" rgba="0.55 0.55 0.55 1"/>
    <geom name="wall_west_inner"  type="box" pos=" 0.5  5.0 0.25" size="0.05 4.5  0.25" rgba="0.55 0.55 0.55 1"/>

  </worldbody>

</mujoco>
