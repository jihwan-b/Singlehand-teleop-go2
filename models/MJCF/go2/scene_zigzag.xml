<mujoco model="go2 zigzag course">
  <include file="go2.xml"/>

  <!--
    Zigzag course: 6 waypoints, 5 segments.
    Robot spawns at wp_0 (0, 0) and navigates to wp_5 (10, 0).

    Waypoints:
      wp_0: ( 0,  0)  ← robot spawn  (red)
      wp_1: ( 2,  3)  top-right
      wp_2: ( 4, -3)  bottom-right
      wp_3: ( 6,  3)  top-right
      wp_4: ( 8, -3)  bottom-right
      wp_5: (10,  0)  ← finish       (green)

    All geoms are non-collision (contype/conaffinity=0).
    Segments use capsule + fromto so orientation is auto-computed.
  -->

  <statistic center="5 0 0" extent="8"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="-130" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
  </asset>

  <worldbody>
    <light pos="5 0 4" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <!-- ── Waypoint poles ──────────────────────────────────────────────────
         Red   = start (robot spawn at 0,0)
         Orange = intermediate turning points
         Green  = finish                                                   -->
    <geom name="wp_0" type="cylinder" pos=" 0  0 0.25" size="0.06 0.25" rgba="1.0 0.1 0.1 1" contype="0" conaffinity="0"/>
    <geom name="wp_1" type="cylinder" pos=" 2  3 0.125" size="0.06 0.125" rgba="1.0 0.5 0.0 0.3" contype="0" conaffinity="0"/>
    <geom name="wp_2" type="cylinder" pos=" 4 -3 0.125" size="0.06 0.125" rgba="1.0 0.5 0.0 0.3" contype="0" conaffinity="0"/>
    <geom name="wp_3" type="cylinder" pos=" 6  3 0.125" size="0.06 0.125" rgba="1.0 0.5 0.0 0.3" contype="0" conaffinity="0"/>
    <geom name="wp_4" type="cylinder" pos=" 8 -3 0.125" size="0.06 0.125" rgba="1.0 0.5 0.0 0.3" contype="0" conaffinity="0"/>
    <geom name="wp_5" type="cylinder" pos="10  0 0.25" size="0.06 0.25" rgba="0.1 0.9 0.1 1" contype="0" conaffinity="0"/>

    <!-- ── Path segments (capsules) ────────────────────────────────────────
         fromto connects consecutive waypoints directly on the ground.    -->
    <geom name="seg_0" type="capsule" fromto=" 0  0 0.04   2  3 0.04" size="0.04" rgba="1 1 0 0.9" contype="0" conaffinity="0"/>
    <geom name="seg_1" type="capsule" fromto=" 2  3 0.04   4 -3 0.04" size="0.04" rgba="1 1 0 0.9" contype="0" conaffinity="0"/>
    <geom name="seg_2" type="capsule" fromto=" 4 -3 0.04   6  3 0.04" size="0.04" rgba="1 1 0 0.9" contype="0" conaffinity="0"/>
    <geom name="seg_3" type="capsule" fromto=" 6  3 0.04   8 -3 0.04" size="0.04" rgba="1 1 0 0.9" contype="0" conaffinity="0"/>
    <geom name="seg_4" type="capsule" fromto=" 8 -3 0.04  10  0 0.04" size="0.04" rgba="1 1 0 0.9" contype="0" conaffinity="0"/>

  </worldbody>

  <!-- Spawn facing +X (default, 0°) -->
  <keyframe>
    <key name="home" qpos="0 0 0.27 1 0 0 0 0 0.9 -1.8 0 0.9 -1.8 0 0.9 -1.8 0 0.9 -1.8"
      ctrl="0 0.9 -1.8 0 0.9 -1.8 0 0.9 -1.8 0 0.9 -1.8" />
  </keyframe>

</mujoco>
